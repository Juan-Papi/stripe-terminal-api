<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Monitor – Stripe Terminal</title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
  <div class="sidebar">
    <div class="logo">
      <span class="logo-icon">⚡</span>
      <span>Stripe Terminal</span>
    </div>
    <nav>
      <a href="/" class="nav-item">Panel</a>
      <a href="/monitor" class="nav-item active">Monitor</a>
    </nav>
    <div class="sidebar-footer">Puerto: <strong><%= port %></strong></div>
  </div>

  <div class="main">
    <div class="header">
      <h1>Monitor de Logs</h1>
      <div class="header-actions">
        <label>
          <input type="checkbox" id="auto-refresh" checked> Auto-refresh
        </label>
        <button class="btn btn-secondary" onclick="clearView()">Limpiar vista</button>
      </div>
    </div>

    <div class="card monitor-card">
      <div id="log-container" class="log-container">
        <p class="text-muted">Cargando logs...</p>
      </div>
    </div>
  </div>

  <script>
    let autoRefresh = true;

    function levelClass(level) {
      return { INFO: 'log-info', WARN: 'log-warn', ERROR: 'log-error', DEBUG: 'log-debug' }[level] || '';
    }

    async function loadLogs() {
      try {
        const res = await fetch('/api/logs?lines=200');
        const data = await res.json();
        const container = document.getElementById('log-container');

        if (!data.logs || data.logs.length === 0) {
          container.innerHTML = '<p class="text-muted">No hay logs aún.</p>';
          return;
        }

        container.innerHTML = data.logs
          .slice().reverse()
          .map(l => `<div class="log-line ${levelClass(l.level)}">
            <span class="log-ts">${l.ts}</span>
            <span class="log-level">${l.level}</span>
            <span class="log-cat">${l.category}</span>
            <span class="log-msg">${escapeHtml(l.message)}</span>
          </div>`).join('');
      } catch (e) {
        document.getElementById('log-container').innerHTML =
          '<p class="text-muted">Error al cargar logs.</p>';
      }
    }

    function clearView() {
      document.getElementById('log-container').innerHTML = '';
    }

    function escapeHtml(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    document.getElementById('auto-refresh').addEventListener('change', e => {
      autoRefresh = e.target.checked;
    });

    loadLogs();
    setInterval(() => { if (autoRefresh) loadLogs(); }, 2000);
  </script>
</body>
</html>
