# Stripe Secret Key (sk_test_... para pruebas, sk_live_... para producción)
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret (obtenlo en Dashboard > Developers > Webhooks > tu endpoint > Signing secret)
# Para desarrollo local usar: stripe listen --forward-to localhost:8001/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Puerto del servidor (por defecto 8001 para no conflictar con red-enlace-api en 8000)
PORT=8001

# Moneda (usd, eur, bob, etc.)
CURRENCY=usd

# Identificador del tótem (para metadata en Stripe)
TOTEM_ID=totem001

# Mapeo de device IDs del totem → label/serial del lector Stripe
# El totem envía "device001", el lector tiene label "PRUEBA"
DEVICE_device001=PRUEBA
APP_BASE_URL=https://tu-dominio.com